// Level 1 AI - 简单搜索（浅深度）
//--------------------------------------------------------------------------------

function xq_EngineLevel1( par_aPos, par_nDepth )
   local l_nMove, l_aMoves, l_i, l_nBestScore, l_nBestMove
   local l_aNewPos, l_nScore

   // 初始化
   if Empty( s_hBoardValues )
      xq_EnginesInit()
   endif

   // 生成所有合法移动
   l_aMoves := pos_GenMoves( par_aPos )

   if Len( l_aMoves ) == 0
      return 0
   endif

   // 默认深度
   if par_nDepth == Nil .OR. par_nDepth < 1
      par_nDepth := 2
   endif

   l_nBestScore := -32000
   l_nBestMove := l_aMoves[1]

   // 简单的 Minimax 搜索
   for l_i := 1 to Len( l_aMoves )
      l_nMove := l_aMoves[l_i]
      l_aNewPos := pos_Move( par_aPos, l_nMove )
      l_nScore := xq_EvaluateWithPST( l_aNewPos )

      // 简单的随机性，增加变化
      l_nScore += hb_Random( 10 )

      if l_nScore > l_nBestScore
         l_nBestScore := l_nScore
         l_nBestMove := l_nMove
      endif
   next

return l_nBestMove

// 使用 PST 评估棋局
//--------------------------------------------------------------------------------

static function xq_EvaluateWithPST( par_aPos )
   local l_cBoard := par_aPos[1]
   local l_nScore := 0
   local l_i, l_c, l_nRow, l_nCol

   // 遍历棋盘
   for l_i := 1 to XQ_BOARD_SIZE
      l_c := SubStr( l_cBoard, l_i, 1 )
      if l_c != "0"
         l_nRow := Int( (l_i - 1) / XQ_BOARD_COLS )
         l_nCol := (l_i - 1) % XQ_BOARD_COLS

         // 基础分值
         if Upper( l_c ) == 'K'
            l_nScore += XQ_VALUE_KING
         elseif Upper( l_c ) == 'A'
            l_nScore += XQ_VALUE_ADV
         elseif Upper( l_c ) == 'B'
            l_nScore += XQ_VALUE_ELEPH
         elseif Upper( l_c ) == 'N'
            l_nScore += XQ_VALUE_HORSE
         elseif Upper( l_c ) == 'R'
            l_nScore += XQ_VALUE_ROOK
         elseif Upper( l_c ) == 'C'
            l_nScore += XQ_VALUE_CANNON
         elseif Upper( l_c ) == 'P'
            l_nScore += XQ_VALUE_PAWN
         endif

         // 位置分值
         if hb_hHasKey( s_hBoardValues, l_c )
            l_nScore += s_hBoardValues[l_c][l_i]
         endif
      endif
   next

   // 黑方视角需要取反
   if !par_aPos[10]
      l_nScore := -l_nScore
   endif

return l_nScore

