# 功能：使用 libeleeye.a 静态库编译测试程序
# 编译命令：hbmk2 -plat=win -comp=mingw64 test.win.hbp
#
# 注意：Windows 版本编译可能需要使用 build.sh 脚本
# 因为 ucrt64 编译器与 -mconsole 选项有兼容性问题
#
# ========================================

# 输出文件名
-otest

# ========================================
# 包含路径
# ========================================
-I.
-Ibase
-Ieleeye

# ========================================
# 库路径
# ====================================
{win}-L/home/woodhead/cchess/eleeye_hb/lib/win/mingw64

# ========================================
# 链接库
# ========================================
-leleeye
-lstdc++
-lpthread

# ========================================
# 源文件
# ========================================
test.prg

# ========================================
# EOF of test.win.hbp
