# ========================================

# 输出文件名
-otest

# ========================================
# 包含路径
# ========================================
-I.
-Ibase
-Ieleeye

# ========================================
# 库路径
# ========================================
-L/home/woodhead/cchess/eleeye_hb/lib/linux/gcc
-L/opt/harbour/lib/linux/gcc

# ========================================
# 链接库
# ========================================
-leleeye
-lstdc++
-lpthread

# ========================================
# 源文件
# ========================================
test.prg

# ========================================
# 编译选项
# ========================================
# 显示执行的命令
-trace

# 显示信息性消息
-info

# 禁用静默模式
-quiet-

